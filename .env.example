# Database
DATABASE_URL="postgresql://user:password@localhost:5432/scoutea"
DIRECT_URL="postgresql://user:password@localhost:5432/scoutea"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key
CLERK_SECRET_KEY=your_secret_key

# Stripe Payment Processing
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Vercel Blob (subida de archivos grandes: import de BD, fotos, etc.)
# Se inyecta automáticamente al conectar un Blob Store al proyecto en Vercel.
# En local, cópialo desde el dashboard de Vercel (Storage → tu Blob Store → .env.local).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Sentry Error Tracking & Performance Monitoring
# Get your DSN from https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id
SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id
SENTRY_ORG=your-organization-slug
SENTRY_PROJECT=your-project-name
SENTRY_AUTH_TOKEN=your-auth-token

# Optional: Enable Sentry in development (by default it's disabled)
# SENTRY_ENABLE_DEV=true

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment
NODE_ENV=development
NEXT_PUBLIC_VERCEL_ENV=development

# Scraping Internal API Key (for backend-to-backend auth)
# Generate a secure random key: openssl rand -base64 32
SCRAPING_INTERNAL_API_KEY=your_secure_random_key_here

# Cron / internal server-to-server auth (REQUIRED in production)
# Autentica el cron de Vercel y los fetches internos a /api/admin/* (scraping
# start → process-auto → process). Sin él, el auto-scraping falla con 401.
# Generate: openssl rand -base64 32
CRON_SECRET=your_secure_random_cron_secret

# Wyscout automation (scripts/wyscout-export.ts)
# Credenciales de la web de Wyscout (login SSO Hudl). Solo se usan en el PRIMER acceso: tras un
# login exitoso se guarda la sesión en .wyscout-session.json y los runs siguientes reautentican
# sin credenciales hasta que esa sesión caduque.
WYSCOUT_USERNAME=your_wyscout_email
WYSCOUT_PASSWORD=your_wyscout_password
# IDs del grupo/subgrupo de listas (por defecto 1395660 / 476805)
WYSCOUT_GROUP_ID=1395660
WYSCOUT_SUBGROUP_ID=476805
